[
  {
    "id": "employee_top_sales",
    "question": "哪个雇员的销售额最高？",
    "expected_tables": ["Employees", "Orders", "Order Details"],
    "expected_columns": [
      {"table": "Employees", "column": "EmployeeID"},
      {"table": "Employees", "column": "FirstName"},
      {"table": "Employees", "column": "LastName"},
      {"table": "Orders", "column": "EmployeeID"},
      {"table": "Orders", "column": "OrderDate"},
      {"table": "Order Details", "column": "UnitPrice"},
      {"table": "Order Details", "column": "Quantity"},
      {"table": "Order Details", "column": "Discount"}
    ],
    "expected_metrics": ["sales_amount"],
    "expected_joins": [
      "Join path: Orders.EmployeeID = Employees.EmployeeID",
      "Join path: Order Details.OrderID = Orders.OrderID"
    ],
    "reference_sql": "SELECT e.FirstName, e.LastName, SUM(od.UnitPrice * od.Quantity * (1 - od.Discount)) AS TotalSales FROM Employees e JOIN Orders o ON e.EmployeeID = o.EmployeeID JOIN [Order Details] od ON o.OrderID = od.OrderID GROUP BY e.EmployeeID ORDER BY TotalSales DESC LIMIT 1;"
  },
  {
