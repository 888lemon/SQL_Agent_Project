  {
    "id": "seafood_suppliers",
    "question": "Seafood 类别的供应商有哪些？",
    "expected_tables": ["Categories", "Products", "Suppliers"],
    "expected_columns": [
      {"table": "Categories", "column": "CategoryName"},
      {"table": "Products", "column": "CategoryID"},
      {"table": "Products", "column": "SupplierID"},
      {"table": "Suppliers", "column": "CompanyName"}
    ],
    "expected_metrics": [],
    "expected_joins": [
      "Join path: Products.CategoryID = Categories.CategoryID",
      "Join path: Products.SupplierID = Suppliers.SupplierID"
    ],
    "reference_sql": "SELECT DISTINCT s.CompanyName FROM Suppliers s JOIN Products p ON s.SupplierID = p.SupplierID JOIN Categories c ON p.CategoryID = c.CategoryID WHERE c.CategoryName = 'Seafood';"
  },
  {
    "id": "customer_order_count",
    "question": "订单量最高的客户是谁？",
    "expected_tables": ["Customers", "Orders"],
    "expected_columns": [
      {"table": "Customers", "column": "CompanyName"},
      {"table": "Orders", "column": "CustomerID"},
      {"table": "Orders", "column": "OrderID"}
    ],
    "expected_metrics": ["order_count"],
    "expected_joins": [
      "Join path: Orders.CustomerID = Customers.CustomerID"
    ],
    "reference_sql": "SELECT c.CompanyName, COUNT(DISTINCT o.OrderID) AS OrderCount FROM Customers c JOIN Orders o ON c.CustomerID = o.CustomerID GROUP BY c.CustomerID ORDER BY OrderCount DESC LIMIT 1;"
  },
  {
    "id": "sales_by_category",
